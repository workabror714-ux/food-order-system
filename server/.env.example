# ── Asosiy ──
MONGODB_URI=mongodb://127.0.0.1:27017/food-order-system
JWT_SECRET=                      # MAJBURIY: uzun tasodifiy satr (produksiyada default ishlatmang!)
PORT=5000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000   # /api/images/... to'liq URL uchun

# ── CORS (vergul bilan ajratilgan ruxsatli domenlar; bo'sh = hammaga ochiq, faqat dev) ──
CORS_ORIGINS=http://localhost:3000

# ── Telegram bot ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                # eski xabar chati (ixtiyoriy)
TELEGRAM_CHANNEL_ID=             # kanal (ixtiyoriy)
TELEGRAM_STAFF_CHAT_ID=          # xodimlar guruhi (tugmali buyurtmalar)
TELEGRAM_WEBHOOK_SECRET=         # webhook himoyasi uchun maxfiy token
TELEGRAM_ALLOWED_CHATS=          # buyruq/tugma ishlatishga ruxsatli chat ID'lar (vergul bilan)

# ── Payme (Merchant API) ──
PAYME_MERCHANT_ID=
PAYME_LOGIN=Paycom
PAYME_KEY=

# ── Click (Shop API) ──
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# ── Millenium Taxi ──
MILLENIUM_ENABLED=false          # "true" qilinsa yetkazib berish narxi/taxi yoqiladi
MILLENIUM_INSECURE_TLS=false     # faqat Millenium self-signed sertifikat ishlatsa "true" qiling (MITM xavfi)
MILLENIUM_API_URL=
MILLENIUM_API_KEY=
MILLENIUM_USER_ID=
MILLENIUM_CLIENT_ID=
MILLENIUM_CREW_GROUP_ID=
# Webhook status mapping (vergul bilan ajratilgan state ID'lar)
MILLENIUM_PREPARING_STATE_IDS=
MILLENIUM_DELIVERED_STATE_IDS=
MILLENIUM_CANCELLED_STATE_IDS=
# Fallback restoran manzili (filial topilmasa)
RESTAURANT_ADDRESS=
RESTAURANT_LAT=41.261532
RESTAURANT_LNG=69.228442

# ── Operatsion sozlamalar ──
AUTO_CANCEL_MINUTES=30           # to'lanmagan onlayn buyurtma necha daqiqada avto-bekor bo'ladi
ORDERS_MY_MAX=30                 # /api/orders/my/:phone rate-limit (oynaga so'rov)
ORDERS_MY_WINDOW_MS=300000       # rate-limit oynasi (ms)
LOGIN_MAX=10                     # login urinishlari (oynaga)
LOGIN_WINDOW_MS=600000           # login rate-limit oynasi (ms)

# Xavfsizlik / rate-limit
NODE_ENV=production
GLOBAL_RATE_MAX=300          # har IP uchun umumiy soʼrov/daqiqa (flood himoyasi)
GLOBAL_RATE_WINDOW_MS=60000
TRUST_PROXY=                 # nginx ortida boʼlsa: 1 (haqiqiy IP uchun)

# ── Masshtablash (ko'p instance) ──
# REDIS_URL qo'yilsa: rate-limit, filial kesh, cron lock instance'lararo ishlaydi.
# Bo'sh bo'lsa: in-memory (bitta instance uchun, lokal/dev).
REDIS_URL=                   # masalan: redis://127.0.0.1:6379
RUN_JOBS=                    # API'da fon jarayonlarini o'chirish uchun: false (alohida `npm run worker` ishlatilsa)

# ── Delever → Neon Alisa ──
# Avval false qoldiring. Base URL va autentifikatsiya formati support bilan
# tasdiqlanib, token/menu testlari muvaffaqiyatli o'tgach true qiling.
DELEVER_ENABLED=false
DELEVER_BASE_URL=
DELEVER_CLIENT_ID=
DELEVER_CLIENT_SECRET=
DELEVER_RESTAURANT_ID=

# API yo'llari (support boshqa yo'l bersa o'zgartiring)
DELEVER_TOKEN_PATH=/v1/security/oauth/token
DELEVER_RESTAURANTS_PATH=/v1/restaurants
DELEVER_MENU_COMPOSITION_PATH=/v1/menu/{restaurantId}/composition
DELEVER_MENU_AVAILABILITY_PATH=/v1/menu/{restaurantId}/availability
DELEVER_ORDER_PATH=/v1/order
DELEVER_ORDER_STATUS_PATH=/v1/order/{orderId}/status
DELEVER_ORDER_CANCEL_PATH=/v1/order/{orderId}

# Token olish usuli:
# auto = Client Secret Base64 username:password ko'rinishida bo'lsa Basic header,
# aks holda client_secret form body'da yuboriladi.
# Variantlar: auto | basic-secret | basic-client | body
DELEVER_TOKEN_AUTH_MODE=auto
DELEVER_GRANT_TYPE=
DELEVER_SCOPE=

# API token headeri. Odatda Bearer; support raw token desa raw yozing.
DELEVER_AUTH_SCHEME=Bearer
DELEVER_PLATFORM=BOT
DELEVER_TIMEOUT_MS=15000

# Buyurtma mapping
DELEVER_ORDER_TYPE_PICKUP=pickup
DELEVER_ORDER_TYPE_DELIVERY=delivery
DELEVER_PAYMENT_TYPE_CASH=cash
DELEVER_PAYMENT_TYPE_CLICK=card
DELEVER_PAYMENT_TYPE_PAYME=card
DELEVER_INCLUDE_EXTERNAL_ID=true
DELEVER_REQUIRE_EXTERNAL_ITEMS=true
DELEVER_ARRIVAL_MINUTES=0

# Menyu Delever'dan kelgach admin panelda qo'lda tahrirlashni bloklaydi.
DELEVER_LOCK_SYNCED_MENU=true

# Fon sinxronizatsiyasi
DELEVER_MENU_SYNC_INTERVAL_MS=300000
DELEVER_ORDER_RETRY_INTERVAL_MS=60000
DELEVER_RETRY_BATCH_SIZE=20
